---
import Font from "astro/components/Font.astro";
import AdminHeader from "../components/AdminHeader.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <Font cssVariable="--font-manrope" preload />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>EPAO Admin Dashboard</title>
  </head>
  <body>
    <AdminHeader />
    <main class="admin-main">
      <slot />
    </main>
  </body>
</html>

<style>
  :global(:root) {
    --border-radius: 12px;
    --black: hsl(0, 0%, 15%);
    --primary-500: #4a6982;
    --primary-600: #3a5468;
    --white: hsl(228, 10%, 95%);
    --button-primary: #4a6982;
    --light-color-bg: hsl(204 29% 86% / 1);
    --lighter-color-bg: hsl(204 29% 90% / 1);
    --smooth-overlay: hsl(146 24% 90% / 1);
    --gray-300: #d1d5db;
    --gray-100: #f3f4f6;
  }

  :global(*) {
    box-sizing: border-box;
    font-family: var(--font-manrope);
  }

  html,
  body {
    padding: 0;
    margin: 0;
    width: 100%;
    height: 100%;
    background-color: var(--white);
    scroll-behavior: smooth;
  }

  .admin-main {
    padding-top: 6rem; /* Header offset */
    padding-left: 2rem;
    padding-right: 2rem;
    padding-bottom: 4rem;
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
    min-height: 100vh;
  }
</style>
