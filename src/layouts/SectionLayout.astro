---
const { title } = Astro.props;
---

<section class="section">
  <div class="header">
    <h2 class="title">{title}</h2>
    <slot name="topComponent" />
  </div>
  <div class="section-content">
    <slot />
  </div>
</section>

<style>
  .section {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem;
    margin: 0 auto;
    max-width: 1200px;
  }

  .section-content {
    margin: 0 auto;
    width: 100%;
  }

  .header {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    align-items: center;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
  }

  .title {
    margin: 0;
    font-size: 2.5rem;
    font-weight: bold;
    color: var(--black);
  }
</style>
