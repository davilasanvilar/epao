---
import Modal from "../../components/Modal.astro";
import { GeneralRequestForm } from "../../components/react/GeneralRequestForm";
import { useTranslations } from "../../i18n";
import Layout from "../../layouts/Layout.astro";
import SectionLayout from "../../layouts/SectionLayout.astro";

const i18n = useTranslations();
---

<Layout>
  <SectionLayout title={i18n.services.title}>
    <div class="services-container">
      <!-- Left sidebar: service list -->
      <div class="services-list" id="services-list">
        <button
          class="service-item active"
          data-service="open-lectures"
          id="service-btn-open-lectures"
        >
          <div class="service-item-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M11 6a13 13 0 0 0 8.4-2.8A1 1 0 0 1 21 4v12a1 1 0 0 1-1.6.8A13 13 0 0 0 11 14H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2z"
              ></path><path d="M6 14a12 12 0 0 0 2.4 7.2 2 2 0 0 0 3.2-2.4A8 8 0 0 1 10 14"
              ></path><path d="M8 6v8"></path></svg
            >
          </div>
          <div class="service-item-text">
            <h3>{i18n.services.openLectures.title}</h3>
            <p>{i18n.services.openLectures.shortDescription}</p>
          </div>
        </button>

        <button class="service-item" data-service="workshops" id="service-btn-workshops">
          <div class="service-item-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M13 7 8.7 2.7a2.41 2.41 0 0 0-3.4 0L2.7 5.3a2.41 2.41 0 0 0 0 3.4L7 13"
              ></path><path d="m8 6 2-2"></path><path d="m18 16 2-2"></path><path
                d="m17 11 4.3 4.3c.94.94.94 2.46 0 3.4l-2.6 2.6c-.94.94-2.46.94-3.4 0L11 17"
              ></path><path
                d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"
              ></path><path d="m15 5 4 4"></path></svg
            >
          </div>
          <div class="service-item-text">
            <h3>{i18n.services.workshops.title}</h3>
            <p>{i18n.services.workshops.shortDescription}</p>
          </div>
        </button>

        <button class="service-item" data-service="support-groups" id="service-btn-support-groups">
          <div class="service-item-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M11 14h2a2 2 0 0 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 16"></path><path
                d="m14.45 13.39 5.05-4.694C20.196 8 21 6.85 21 5.75a2.75 2.75 0 0 0-4.797-1.837.276.276 0 0 1-.406 0A2.75 2.75 0 0 0 11 5.75c0 1.2.802 2.248 1.5 2.946L16 11.95"
              ></path><path d="m2 15 6 6"></path><path
                d="m7 20 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a1 1 0 0 0-2.75-2.91"
              ></path></svg
            >
          </div>
          <div class="service-item-text">
            <h3>{i18n.services.supportGroups.title}</h3>
            <p>{i18n.services.supportGroups.shortDescription}</p>
          </div>
        </button>

        <button class="service-item" data-service="counselling" id="service-btn-counselling">
          <div class="service-item-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><path
                d="m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z"
              ></path></svg
            >
          </div>
          <div class="service-item-text">
            <h3>{i18n.services.counselling.title}</h3>
            <p>{i18n.services.counselling.shortDescription}</p>
          </div>
        </button>
      </div>

      <!-- Right panel: service detail -->
      <div class="service-detail" id="service-detail">
        <!-- Open Lectures -->
        <div class="detail-panel active" data-panel="open-lectures" id="panel-open-lectures">
          <div class="detail-image">
            <img
              src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=800&h=400&fit=crop"
              alt="Open lectures session"
              loading="lazy"
            />
          </div>
          <div class="detail-content">
            <h2>{i18n.services.openLectures.title}</h2>
            <p class="detail-description">
              {i18n.services.openLectures.description}
            </p>
            <div class="pricing">
              <div class="detail-pricing">
                <div class="price-card">
                  <span class="price-curr">{i18n.services.currency}</span>
                  <span class="price-value">{i18n.services.free}</span>
                </div>
              </div>
              <button class="request-btn" command="show-modal" commandfor="contact-modal">
                {i18n.services.requestInfo}
              </button>
            </div>
          </div>
        </div>

        <!-- Training courses -->
        <div class="detail-panel" data-panel="workshops" id="panel-workshops">
          <div class="detail-image">
            <img
              src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&h=400&fit=crop"
              alt="Professional workshop"
              loading="lazy"
            />
          </div>
          <div class="detail-content">
            <h2>{i18n.services.workshops.title}</h2>
            <p class="detail-description">
              {i18n.services.workshops.description}
            </p>
            <div class="pricing">
              <div class="detail-pricing">
                <div class="price-card">
                  <span class="price-curr">{i18n.services.currency}</span>
                  <span class="price-value">{"*"}</span>
                </div>
                <span class="price-aclaration">
                  {i18n.services.onRequest}
                </span>
              </div>
              <button class="request-btn" command="show-modal" commandfor="contact-modal">
                {i18n.services.requestInfo}
              </button>
            </div>
          </div>
        </div>

        <!-- Support Groups -->
        <div class="detail-panel" data-panel="support-groups" id="panel-support-groups">
          <div class="detail-image">
            <img
              src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=800&h=400&fit=crop"
              alt="Support group session"
              loading="lazy"
            />
          </div>
          <div class="detail-content">
            <h2>{i18n.services.supportGroups.title}</h2>
            <p class="detail-description">
              {i18n.services.supportGroups.description}
            </p>
            <div class="pricing">
              <div class="detail-pricing">
                <div class="price-card">
                  <span class="price-curr">{i18n.services.currency}</span>
                  <span class="price-value">{i18n.services.free}</span>
                </div>
              </div>
              <button class="request-btn" command="show-modal" commandfor="contact-modal">
                {i18n.services.requestInfo}
              </button>
            </div>
          </div>
        </div>

        <!-- Counselling -->
        <div class="detail-panel" data-panel="counselling" id="panel-counselling">
          <div class="detail-image">
            <img
              src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=800&h=400&fit=crop"
              alt="Counselling session"
              loading="lazy"
            />
          </div>
          <div class="detail-content">
            <h2>{i18n.services.counselling.title}</h2>
            <p class="detail-description">
              {i18n.services.counselling.description}
            </p>
            <div class="pricing">
              <div class="detail-pricing">
                <div class="price-card">
                  <span class="price-curr">{i18n.services.currency}</span>
                  <span class="price-value">{i18n.services.price50}</span>
                </div>
                <span class="price-aclaration">
                  {i18n.services.canBeAdjusted}
                </span>
              </div>
              <button class="request-btn" command="show-modal" commandfor="contact-modal">
                {i18n.services.requestInfo}
              </button>
            </div>
          </div>
        </div>
        <Modal id="contact-modal" title={i18n.services.requestInfo}>
          <GeneralRequestForm client:load />
        </Modal>
      </div>
    </div>
  </SectionLayout>

  <style>
    .services-page {
      padding-top: 5rem;
    }

    /* ── Hero ── */
    .services-hero {
      background: linear-gradient(
        135deg,
        hsl(213 22% 86% / 1) 0%,
        hsl(204 29% 90% / 1) 50%,
        hsl(213 22% 86% / 1) 100%
      );
      padding: 5rem 2rem 4rem;
      text-align: center;
    }

    .services-hero-content {
      max-width: 700px;
      margin: 0 auto;
    }

    .services-hero-content h1 {
      font-size: 2.75rem;
      font-weight: 900;
      color: var(--black);
      margin: 0 0 1rem;
      letter-spacing: -0.02em;
    }

    .services-hero-content p {
      font-size: 1.125rem;
      line-height: 1.8;
      color: var(--primary-500);
      max-width: 600px;
      margin: 0 auto;
    }

    /* ── Main Section ── */
    .services-section {
      padding: 3rem 2rem 5rem;
      max-width: 1280px;
      margin: 0 auto;
    }

    .services-container {
      display: flex;
      gap: 2.5rem;
      align-items: flex-start;
    }

    /* ── Left Sidebar ── */
    .services-list {
      flex: 0 0 320px;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      position: sticky;
      top: 7rem;
    }

    .service-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.25rem 1.5rem;
      border-radius: var(--border-radius);
      cursor: pointer;
      border: 2px solid transparent;
      background: transparent;
      text-align: left;
      font-family: inherit;
    }

    .service-item.active {
      background: white;
      border-color: var(--primary-500);
      box-shadow:
        0 4px 20px hsl(203 18% 40% / 0.1),
        0 1px 4px hsl(203 18% 40% / 0.08);
    }

    .service-item.active .service-item-icon {
      color: white;
      background: var(--primary-500);
    }

    .service-item-icon {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 2.75rem;
      height: 2.75rem;
      min-width: 2.75rem;
      border-radius: 10px;
      color: var(--primary-500);
      background: hsl(213 22% 86% / 0.7);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .service-item-icon svg {
      width: 1.375rem;
      height: 1.375rem;
    }

    .service-item-text h3 {
      margin: 0;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--black);
      line-height: 1.3;
    }

    .service-item-text p {
      margin: 0.25rem 0 0;
      font-size: 0.8rem;
      color: hsl(0 0% 45%);
      line-height: 1.4;
      font-weight: 400;
    }

    /* ── Right Detail Panel ── */
    .service-detail {
      flex: 1;
      position: relative;
      min-height: 600px;
    }

    .detail-panel {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      opacity: 0;
      transform: translateY(12px);
      pointer-events: none;
      transition:
        opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .detail-panel.active {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
      position: relative;
    }

    .detail-image {
      border-radius: var(--border-radius);
      overflow: hidden;
      margin-bottom: 2rem;
      box-shadow:
        0 8px 30px hsl(203 18% 40% / 0.12),
        0 2px 8px hsl(203 18% 40% / 0.06);
    }

    .detail-image img {
      width: 100%;
      height: 280px;
      object-fit: cover;
      display: block;
    }

    .detail-content {
      padding: 0 0.5rem;
    }

    .detail-content h2 {
      font-size: 2rem;
      font-weight: 800;
      margin: 0 0 1.25rem;
      color: var(--black);
      letter-spacing: -0.01em;
    }

    .detail-description {
      font-size: 1rem;
      line-height: 1.8;
      color: hsl(0 0% 30%);
      margin: 0 0 1rem;
      font-weight: 300;
    }

    /* ── Pricing Cards ── */
    .pricing {
      display: flex;
      gap: 1rem;
      margin-top: 2rem;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .detail-pricing {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .price-card {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      padding: 1.25rem 1.5rem;
      border-radius: var(--border-radius);
      background: linear-gradient(135deg, hsl(213 22% 94%) 0%, hsl(204 29% 92%) 100%);
      border: 1px solid hsl(213 22% 86% / 0.8);
      min-width: 160px;
      flex: 1;
      transition: all 0.25s ease;
      max-width: 250px;
    }

    @media (max-width: 450px) {
      .price-card {
        width: 100%;
        max-width: none;
      }
      .detail-pricing {
        width: 100%;
      }
    }

    .price-curr {
      font-size: 1.75rem;
      font-weight: 500;
      color: hsl(207 28% 65%);
      line-height: 1.3;
    }

    .price-value {
      font-size: 1.5rem;
      font-weight: 800;
      color: var(--primary-500);
      letter-spacing: -0.02em;
    }
    .price-value-small {
      font-size: 1rem;
      font-weight: 800;
      color: var(--primary-500);
      letter-spacing: -0.02em;
    }

    .price-aclaration {
      font-size: 1rem;
      color: hsl(207 28% 45%);
      letter-spacing: -0.02em;
      margin-bottom: 1rem;
      display: block;
      margin: 0;
      margin-top: 0.5rem;
    }

    /* ── CTA Button ── */
    .request-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.875rem 2rem;
      background: var(--primary-500);
      color: white;
      border: none;
      border-radius: var(--border-radius);
      font-size: 1rem;
      font-weight: 700;
      height: 4rem;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 2px 8px hsl(203 18% 40% / 0.2);
    }

    @media (max-width: 450px) {
      .request-btn {
        width: 100%;
        justify-content: center;
      }
    }

    .request-btn:hover {
      background: hsl(207 28% 35%);
      box-shadow: 0 4px 16px hsl(203 18% 40% / 0.3);
      transform: translateY(-1px);
    }

    .request-btn:active {
      transform: translateY(0);
    }

    /* ── Responsive ── */
    @media (max-width: 860px) {
      .services-container {
        flex-direction: column;
      }

      .services-list {
        flex: none;
        width: 100%;
        position: static;
        flex-direction: row;
        overflow-x: auto;
        gap: 0.75rem;
        padding-bottom: 0.5rem;
        flex-wrap: wrap;
      }

      .service-item {
        flex: 0 0 auto;
        padding: 1rem 0.75rem;
        width: calc(50% - 0.375rem);
      }

      .service-item-text p {
        display: none;
      }

      .service-detail {
        min-height: auto;
      }

      .detail-panel {
        position: relative;
        display: none;
      }

      .detail-panel.active {
        display: block;
      }
    }
  </style>

  <script>
    document.addEventListener("astro:page-load", () => {
      const serviceItems = document.querySelectorAll(".service-item");
      const detailPanels = document.querySelectorAll(".detail-panel");

      serviceItems.forEach((item) => {
        item.addEventListener("click", () => {
          const serviceId = item.getAttribute("data-service");

          // Update active states on sidebar items
          serviceItems.forEach((si) => si.classList.remove("active"));
          item.classList.add("active");

          // Transition panels
          detailPanels.forEach((panel) => {
            if (panel.getAttribute("data-panel") === serviceId) {
              panel.classList.add("active");
            } else {
              panel.classList.remove("active");
            }
          });
        });
      });
    });
  </script>
</Layout>
