---
export const prerender = true;

import SectionLayout from "../../layouts/SectionLayout.astro";
import ResourcesList from "../../components/ResourcesList.astro";
import { getTursoClient } from "../../lib/tursoclient";
import type { GetStaticPaths, Page } from "astro";
import Layout from "../../layouts/Layout.astro";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const url =
    import.meta.env.TURSO_CONNECTION_URL || process.env.TURSO_CONNECTION_URL;
  const token =
    import.meta.env.TURSO_AUTH_TOKEN || process.env.TURSO_AUTH_TOKEN;

  if (!url || !token) {
    console.error("Missing Turso configuration for SSG build.");
    return [
      {
        params: { page: undefined },
        props: {
          page: {
            data: [],
            currentPage: 1,
            lastPage: 1,
            url: { prev: undefined, next: undefined },
          },
        },
      },
    ];
  }

  const turso = getTursoClient(url, token);

  const sqlData = `SELECT * FROM resources ORDER BY created_at DESC`;
  const dataResult = await turso.execute(sqlData);

  const resources = dataResult.rows.map((row) => ({
    id: row.id,
    name: row.name,
    isVideo: row.isVideo,
    url: row.url,
    description: row.description,
    img: row.img,
    created_at: row.created_at,
  }));

  const paths = paginate(resources, { pageSize: 6 });
  if (paths.length === 0) {
    return [
      {
        params: { page: undefined },
        props: {
          page: {
            data: [],
            currentPage: 1,
            lastPage: 1,
            url: { prev: undefined, next: undefined },
          },
        },
      },
    ];
  }
  return paths;
};

const { page } = Astro.props as {
  page: Page;
};
---

<Layout>
  <SectionLayout title="Our Resources">
    <ResourcesList page={page} />
  </SectionLayout>
</Layout>
