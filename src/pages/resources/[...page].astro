---
import SectionLayout from "../../layouts/SectionLayout.astro";
import ResourcesList from "../../components/ResourcesList.astro";
import { getTursoClient } from "../../lib/tursoclient";
import Layout from "../../layouts/Layout.astro";
import { env } from "cloudflare:workers";
import { useTranslations } from "../../i18n";

const PAGE_SIZE = 6;
const rawPage = Astro.params.page;
const currentPage = rawPage ? parseInt(rawPage, 10) : 1;
const i18n = useTranslations();

const url = env.TURSO_CONNECTION_URL || import.meta.env.TURSO_CONNECTION_URL;
const token = env.TURSO_AUTH_TOKEN || import.meta.env.TURSO_AUTH_TOKEN;

const emptyPage = {
  data: [],
  currentPage: 1,
  lastPage: 1,
  url: { prev: undefined, next: undefined },
};

if (!url || !token) {
  console.error("Missing Turso configuration.");
}

const turso = url && token ? getTursoClient(url, token) : null;

let resources: any[] = [];
let totalCount = 0;

if (turso) {
  const countResult = await turso.execute(`SELECT COUNT(*) as count FROM resources`);
  totalCount = Number(countResult.rows[0]?.count ?? 0);

  const offset = (currentPage - 1) * PAGE_SIZE;
  const dataResult = await turso.execute({
    sql: `SELECT * FROM resources ORDER BY created_at DESC LIMIT ? OFFSET ?`,
    args: [PAGE_SIZE, offset],
  });

  resources = dataResult.rows.map((row: any) => ({
    id: row.id,
    name: row.name,
    isVideo: row.isVideo,
    url: row.url,
    description: row.description,
    img: row.img,
    created_at: row.created_at,
  }));
}

const lastPage = Math.max(1, Math.ceil(totalCount / PAGE_SIZE));

const page = {
  data: resources,
  currentPage,
  lastPage,
  url: {
    prev:
      currentPage > 1
        ? currentPage === 2
          ? "/resources"
          : `/resources/${currentPage - 1}`
        : undefined,
    next: currentPage < lastPage ? `/resources/${currentPage + 1}` : undefined,
  },
};
---

<Layout>
  <SectionLayout title={i18n.resources.title}>
    <ResourcesList page={page} />
  </SectionLayout>
</Layout>