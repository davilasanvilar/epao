---
export const prerender = true;

import Layout from "../../layouts/Layout.astro";
import EventsList from "../../components/EventsList.astro";
import { getTursoClient } from "../../lib/tursoclient";

export async function getStaticPaths({ paginate }) {
  const url = import.meta.env.TURSO_CONNECTION_URL || process.env.TURSO_CONNECTION_URL;
  const token = import.meta.env.TURSO_AUTH_TOKEN || process.env.TURSO_AUTH_TOKEN;

  if (!url || !token) {
    console.error("Missing Turso configuration for SSG build.");
    return paginate([], { pageSize: 6 });
  }

  const turso = getTursoClient(url, token);

  const sqlData = `SELECT * FROM events WHERE substr(date, 1, 10) >= date('now', 'localtime') ORDER BY date ASC`;
  const dataResult = await turso.execute(sqlData);

  const events = dataResult.rows.map(row => ({
    id: row.id,
    name: row.name,
    description: row.description,
    price: row.price,
    date: row.date,
    img: row.img,
  }));

  return paginate(events, { pageSize: 6 });
}

const { page } = Astro.props;
---

<Layout>
  <main class="events-page-container">
    <section class="section">
      <div class="section-content">
        <EventsList page={page} eventType="future" />
      </div>
    </section>
  </main>
</Layout>

<style>
  .events-page-container {
    padding-top: 6rem;
    min-height: calc(100vh - 200px);
  }
  
  .section {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 0;
  }
  
  .section-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    width: 100%;
  }
</style>
