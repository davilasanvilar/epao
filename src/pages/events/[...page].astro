---
export const prerender = true;

import EventsList from "../../components/EventsList.astro";
import { getTursoClient } from "../../lib/tursoclient";
import SectionLayout from "../../layouts/SectionLayout.astro";
import EventTabs from "../../components/EventTabs.astro";

export async function getStaticPaths({ paginate }) {
  const url =
    import.meta.env.TURSO_CONNECTION_URL || process.env.TURSO_CONNECTION_URL;
  const token =
    import.meta.env.TURSO_AUTH_TOKEN || process.env.TURSO_AUTH_TOKEN;

  if (!url || !token) {
    console.error("Missing Turso configuration for SSG build.");
    return [
      {
        params: { page: undefined },
        props: {
          page: {
            data: [],
            currentPage: 1,
            lastPage: 1,
            url: { prev: undefined, next: undefined },
          },
        },
      },
    ];
  }

  const turso = getTursoClient(url, token);

  const sqlData = `SELECT * FROM events WHERE substr(date, 1, 10) >= date('now', 'localtime') ORDER BY date ASC`;
  const dataResult = await turso.execute(sqlData);

  const events = dataResult.rows.map((row) => ({
    id: row.id,
    name: row.name,
    description: row.description,
    price: row.price,
    date: row.date,
    img: row.img,
  }));

  const paths = paginate(events, { pageSize: 6 });
  if (paths.length === 0) {
    return [
      {
        params: { page: undefined },
        props: {
          page: {
            data: [],
            currentPage: 1,
            lastPage: 1,
            url: { prev: undefined, next: undefined },
          },
        },
      },
    ];
  }
  return paths;
}

const { page } = Astro.props;
---

<SectionLayout title="Our Events">
  <EventTabs slot="topComponent" />
  <EventsList page={page} eventType="future" />
</SectionLayout>
