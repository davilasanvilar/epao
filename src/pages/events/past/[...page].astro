---
import EventsList from "../../../components/EventsList.astro";
import SectionLayout from "../../../layouts/SectionLayout.astro";
import EventTabs from "../../../components/EventTabs.astro";
import Layout from "../../../layouts/Layout.astro";

const rawPage = Astro.params.page;
const currentPage = rawPage ? parseInt(rawPage, 10) : 1;
---

<Layout>
  <SectionLayout title="Our Events">
    <EventTabs slot="topComponent" />
    <EventsList eventType="past" currentPage={currentPage} />
  </SectionLayout>
</Layout>
