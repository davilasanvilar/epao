---
import { useTranslations } from "../../i18n";
import aboutOrgImg from "../../assets/lecture.webp";
import TeamCards from "../../components/TeamCards.astro";
import Layout from "../../layouts/Layout.astro";
import SectionLayout from "../../layouts/SectionLayout.astro";

const i18n = useTranslations();
---

<Layout>
  <SectionLayout title={i18n.about.title}>
    <div class="about-mission-content">
      <div class="about-top-wrapper">
        <div class="about-mission-text">
          {i18n.about.description.map((desc) => <p>{desc}</p>)}
        </div>
        <div class="about-mission-image-wrapper">
          <img src={aboutOrgImg.src} alt={i18n.about.imageAlt} class="about-mission-image" />
        </div>
      </div>
    </div>
    <SectionLayout title={i18n.about.meetTeam} isSubSection>
      <TeamCards />
    </SectionLayout>
  </SectionLayout>

  <!-- Team Section -->

  <style>
    /* ===== Mission Section ===== */
    .about-mission {
      background: var(--white);
      padding: 6rem 2rem;
    }

    .about-mission-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5rem;
    }

    .about-top-wrapper {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 5rem;
    }

    @media (max-width: 1024px) {
      .about-top-wrapper {
        flex-direction: column;
        gap: 2rem;
      }
    }

    .about-mission-text {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .about-mission-text h2 {
      font-size: 2.25rem;
      font-weight: 800;
      color: var(--black);
      margin-bottom: 0.5rem;
    }

    .about-mission-image-wrapper {
      position: relative;
      flex: 0 0 45%;
    }

    .about-mission-image {
      width: 100%;
      border-radius: 16px;
      object-fit: cover;
      position: relative;
      z-index: 1;
      box-shadow: 0 20px 60px hsl(207 30% 30% / 0.15);
    }

    /* ===== Team Section ===== */
    .about-team {
      background: linear-gradient(180deg, var(--white) 0%, hsl(213 22% 92%) 100%);
      padding: 6rem 2rem 8rem;
    }

    .about-team-inner {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
    }

    .about-team-header {
      text-align: center;
      margin-bottom: 4rem;
    }

    .about-team-header h2 {
      font-size: 2.25rem;
      font-weight: 800;
      margin: 0.75rem 0 1rem;
    }

    .about-team-subtitle {
      max-width: 32rem;
      margin: 0 auto !important;
      color: hsl(0 0% 45%) !important;
    }
  </style></Layout
>
