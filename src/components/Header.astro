---
import Button from "./Button.astro";
import logo from "../assets/logo.svg";
import Modal from "./Modal.astro";
import { GeneralRequestForm } from "./react/GeneralRequestForm";
const path = Astro.url.pathname;
---

<header>
  <div id="logo-container">
    <img src={logo.src} alt="" width="40" height="40" />
    <span class="logo">EPAO</span>
  </div>

  <!-- Desktop nav (hidden on mobile) -->
  <nav class="desktop-nav">
    <ul>
      <li class={`nav-item ${path === "/" ? "active" : ""}`}>
        <a href="/">Home</a>
      </li>
      <li class={`nav-item ${path.startsWith("/about") ? "active" : ""}`}>
        <a href="/about">About us</a>
      </li>
      <li class={`nav-item ${path === "/services" ? "active" : ""}`}>
        <a href="/services">Services</a>
      </li>
      <li class={`nav-item ${path.startsWith("/events") ? "active" : ""}`}>
        <a href="/events">Events</a>
      </li>
      <li class={`nav-item ${path === "/resources" ? "active" : ""}`}>
        <a href="/resources">Resources</a>
      </li>
    </ul>
  </nav>

  <div class="desktop-cta">
    <Button variant="primary" text="Contact us" command="show-modal" commandFor="contact-modal" />
  </div>

  <!-- Hamburger button (visible on mobile) -->
  <button class="hamburger" id="hamburger-btn" aria-label="Open menu">
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
  </button>

  <Modal id="contact-modal" title="Contact us">
    <GeneralRequestForm client:load />
  </Modal>
</header>

<!-- Sidebar overlay -->
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<!-- Sidebar menu -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <span class="sidebar-title">Menu</span>
    <button class="sidebar-close" id="sidebar-close" aria-label="Close menu">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>
  <nav class="sidebar-nav">
    <a href="/" class={`sidebar-link ${path === "/" ? "active" : ""}`}>Home</a>
    <a href="/about" class={`sidebar-link ${path.startsWith("/about") ? "active" : ""}`}>About us</a
    >
    <a href="/services" class={`sidebar-link ${path === "/services" ? "active" : ""}`}>Services</a>
    <a href="/events" class={`sidebar-link ${path.startsWith("/events") ? "active" : ""}`}>Events</a
    >
    <a href="/resources" class={`sidebar-link ${path === "/resources" ? "active" : ""}`}
      >Resources</a
    >
  </nav>
  <div class="sidebar-cta">
    <Button variant="primary" text="Contact us" command="show-modal" commandFor="contact-modal" />
  </div>
</aside>

<style>
  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 5rem;
    padding: 1rem 1.5rem;
    position: fixed;
    top: 0;
    z-index: 1000;
    background-color: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }

  #logo-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--primary-500);
  }

  /* ---- Desktop nav ---- */
  .desktop-nav ul {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .desktop-cta {
    display: block;
  }

  .nav-item {
    margin-right: 1rem;
    list-style: none;
  }

  .nav-item a {
    text-decoration: none;
    color: var(--primary-500);
  }

  .active {
    color: var(--button-primary);
    padding-bottom: 0.25rem;
    font-weight: bold;
  }

  /* ---- Hamburger button ---- */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 1100;
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2.5px;
    background: var(--primary-500);
    border-radius: 2px;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  /* ---- Sidebar overlay ---- */
  .sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 2000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .sidebar-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  /* ---- Sidebar ---- */
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    width: 280px;
    max-width: 80vw;
    background: var(--white, #fff);
    z-index: 2100;
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    box-shadow: 2px 0 12px rgba(0, 0, 0, 0.15);
  }

  .sidebar.open {
    transform: translateX(0);
  }

  .sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .sidebar-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--primary-500);
  }

  .sidebar-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--primary-500);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: background 0.2s;
  }

  .sidebar-close:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .sidebar-link {
    text-decoration: none;
    color: var(--primary-500);
    font-size: 1.1rem;
    font-weight: 500;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    transition: background 0.2s;
  }

  .sidebar-link:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .sidebar-link.active {
    color: var(--button-primary);
    font-weight: 700;
    background: rgba(74, 105, 130, 0.08);
  }

  .sidebar-cta {
    margin-top: 1.5rem;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1023px) {
    .desktop-nav,
    .desktop-cta {
      display: none;
    }

    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  function initSidebar() {
    const hamburger = document.getElementById("hamburger-btn");
    const sidebar = document.getElementById("sidebar");
    const overlay = document.getElementById("sidebar-overlay");
    const closeBtn = document.getElementById("sidebar-close");

    if (!hamburger || !sidebar || !overlay || !closeBtn) return;

    function openSidebar() {
      sidebar.classList.add("open");
      overlay.classList.add("open");
      document.body.style.overflow = "hidden";
    }

    function closeSidebar() {
      sidebar.classList.remove("open");
      overlay.classList.remove("open");
      document.body.style.overflow = "";
    }

    hamburger.addEventListener("click", openSidebar);
    closeBtn.addEventListener("click", closeSidebar);
    overlay.addEventListener("click", closeSidebar);

    // Close sidebar when a link inside is clicked
    sidebar.querySelectorAll(".sidebar-link").forEach((link) => {
      link.addEventListener("click", () => {
        closeSidebar();
      });
    });
  }

  // Run on initial load
  initSidebar();

  // Re-run after Astro page swaps
  document.addEventListener("astro:after-swap", initSidebar);
</script>
