---
import Modal from "./Modal.astro";
import { useTranslations } from "../i18n";

export interface Props {
  resource: {
    id: number;
    name: string;
    isVideo: boolean | number;
    url: string | null;
    description: string;
    img: string;
  };
}

const { resource } = Astro.props;
const i18n = useTranslations();
const isVideo = resource.isVideo === true || resource.isVideo === 1;
const videoId = resource.url?.split("v=")[1];

// Use the image key to build the URL to our dynamic endpoint, fallback to placeholder
const imageUrl = resource.isVideo
  ? `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`
  : resource.img
    ? `/api/b2-image?key=${encodeURIComponent(resource.img)}`
    : "https://placehold.co/400x300?text=No+Image";

const modalId = `resource-modal-${resource.id}`;

function getYouTubeEmbedUrl(url: string | null): string {
  if (!url) return "";
  try {
    const urlObj = new URL(url);
    let videoId = "";
    if (urlObj.hostname.includes("youtube.com")) {
      videoId = urlObj.searchParams.get("v") || "";
    } else if (urlObj.hostname.includes("youtu.be")) {
      videoId = urlObj.pathname.slice(1);
    }
    return videoId ? `https://www.youtube.com/embed/${videoId}` : url;
  } catch {
    return url || "";
  }
}

const embedUrl = isVideo ? getYouTubeEmbedUrl(resource.url) : "";
---

<!-- The Card -->
<div class="resource-card" role="button" tabindex="0" data-modal-target={modalId}>
  <div class="resource-img-wrapper">
    <img src={imageUrl} alt={resource.name} class="resource-img" loading="lazy" />
    <div class="resource-type-badge">
      {
        isVideo ? (
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
            stroke="none"
          >
            <polygon points="5 3 19 12 5 21 5 3" />
          </svg>
        ) : (
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="16" y1="13" x2="8" y2="13" />
            <line x1="16" y1="17" x2="8" y2="17" />
            <polyline points="10 9 9 9 8 9" />
          </svg>
        )
      }
      <span>{isVideo ? i18n.resources.video : i18n.resources.article}</span>
    </div>
  </div>

  <div class="resource-content">
    <h3 class="resource-title">{resource.name}</h3>
  </div>
</div>

<!-- The Modal -->
<Modal id={modalId} title={resource.name}>
  <div class="modal-layout">
    <div class="modal-left">
      {
        isVideo && embedUrl ? (
          <div class="video-embed-wrapper">
            <iframe
              src={embedUrl}
              title={resource.name}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          </div>
        ) : (
          <img src={imageUrl} alt={resource.name} class="modal-img" loading="lazy" />
        )
      }
    </div>
    <div class={`modal-right ${isVideo ? "modal-right-video" : ""}`}>
      <div class="modal-type-badge">
        {
          isVideo ? (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              stroke="none"
            >
              <polygon points="5 3 19 12 5 21 5 3" />
            </svg>
          ) : (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="16" y1="13" x2="8" y2="13" />
              <line x1="16" y1="17" x2="8" y2="17" />
              <polyline points="10 9 9 9 8 9" />
            </svg>
          )
        }
        <span>{isVideo ? i18n.resources.video : i18n.resources.article}</span>
      </div>
      <p class="modal-description">{resource.description}</p>
    </div>
  </div>
</Modal>

<style>
  /* Override default modal width for resource modals */
  :global(dialog[id^="resource-modal-"]) {
    width: 55rem !important;
    max-width: 95vw !important;
  }

  /* Remove extra margin from empty title in modal header */
  :global(dialog[id^="resource-modal-"] .header .title:empty) {
    display: none;
  }

  /* Card Styles */
  .resource-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow:
      0 4px 6px -1px rgb(0 0 0 / 0.1),
      0 2px 4px -2px rgb(0 0 0 / 0.1);
    cursor: pointer;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    user-select: none;
  }

  .resource-card:focus-visible {
    outline: 2px solid var(--primary-500);
    outline-offset: 2px;
  }

  .resource-img-wrapper {
    position: relative;
    overflow: hidden;
  }

  .resource-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .resource-type-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    background-color: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(4px);
    color: var(--primary-500);
    font-size: 0.8125rem;
    font-weight: 600;
    box-shadow: 0 1px 4px rgb(0 0 0 / 0.12);
  }

  .resource-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    background: white;
    z-index: 1;
  }

  .resource-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--black);
    line-height: 1.3;
  }

  /* Modal Layout Styles */
  .modal-layout {
    display: flex;
    gap: 2rem;
    flex-direction: row;
    align-items: flex-start;
  }

  @media (max-width: 768px) {
    .modal-layout {
      flex-direction: column;
    }
    .modal-left {
      width: 100%;
    }
  }

  .modal-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .modal-img {
    width: 100%;
    border-radius: var(--border-radius);
    object-fit: contain;
    aspect-ratio: 16 / 9;
  }

  .video-embed-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    border-radius: var(--border-radius);
    overflow: hidden;
    background: #000;
  }

  .video-embed-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .modal-title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--black);
  }

  .modal-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .modal-right-video {
    flex: 0.5 !important;
  }

  .modal-right-article {
    flex: 1;
  }

  .modal-type-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    width: fit-content;
    background-color: hsl(213 22% 92%);
    color: var(--primary-500);
  }

  .modal-description {
    margin: 0;
    color: var(--black);
    opacity: 0.9;
    font-size: 1rem;
    line-height: 1.6;
    white-space: pre-line;
  }
</style>

<script>
  function initializeResourceCards() {
    const cards = document.querySelectorAll(".resource-card");
    cards.forEach((card) => {
      if (card.hasAttribute("data-initialized")) return;

      const targetId = card.getAttribute("data-modal-target");
      if (!targetId) return;

      const modal = document.getElementById(targetId) as HTMLDialogElement | null;

      if (modal) {
        const openModal = () => {
          modal.showModal();
        };

        card.addEventListener("click", openModal);
        card.addEventListener("keydown", (e: Event) => {
          const keyboardEvent = e as KeyboardEvent;
          if (keyboardEvent.key === "Enter" || keyboardEvent.key === " ") {
            e.preventDefault();
            openModal();
          }
        });
      }

      card.setAttribute("data-initialized", "true");
    });
  }

  initializeResourceCards();
  document.addEventListener("astro:page-load", initializeResourceCards);
</script>