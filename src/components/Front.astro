---
import toys from "../assets/toys2.jpg";
import EducationIcon from "./icons/EducationIcon.astro";
import EyeIcon from "./icons/EyeIcon.astro";
import ScaleIcon from "./icons/ScaleIcon.astro";
import PillarCard from "./PillarCard.astro";
---

<div id="container">
  <main class="hero-section">
    <section id="hero">
      <div id="hero-content">
        <h1>Prevention of Emotional and Psychological Abuse</h1>
        <p>
          A professional organization which works for the protection of children through education,
          support, and systemic change.
        </p>
      </div>
      <div class="pillars">
        <PillarCard
          title="Awareness"
          description="Raising public consciousness about the hidden signs of psychological abuse to ensure every child is seen and heard."
        >
          <EyeIcon slot="icon" />
        </PillarCard>
        <PillarCard
          title="Education"
          description="Providing specialized training for professionals and caregivers to effectively identify and intervene in coercive environments."
        >
          <EducationIcon slot="icon" />
        </PillarCard>
        <PillarCard
          title="Legislative"
          description="Championing policy reform and legal advocacy to strengthen protections and secure justice for children in the legal system."
        >
          <ScaleIcon slot="icon" />
        </PillarCard>
      </div>
    </section>
  </main>
</div>

<style>
  .hero-section {
    width: 100%;
    min-height: 90vh;
  }

  .section-page-container {
    padding-top: 6rem;
    min-height: calc(100vh - 200px);
  }

  .section {
    padding: 5rem 2rem;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .section-content {
    display: flex;
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
  }

  #container {
    position: relative;
    min-height: calc(100vh);
  }
  #background {
    width: 100%;
    height: 100vh;
    background-image: linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.9)), url("image.jpg");
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    z-index: -1;
  }

  h1 {
    font-weight: 900;
    line-height: 4rem;
    font-size: 3rem;
    color: var(--black);
    margin: 0;
  }

  @media (max-width: 1024px) {
    h1 {
      font-size: 3rem;
      line-height: 3rem;
    }
  }

  p {
    text-align: center;
  }

  main {
    position: absolute;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100vh;
    top: 0;
    color: "black";

    background-image:
      linear-gradient(to bottom, hsl(213 22% 86% / 0.9) 100%, hsl(213 22% 86% / 0) 10%),
      url("../assets/toys.jpg");
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
  }

  #hero {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    gap: 10vh;
    padding: 0 3.5rem;
  }
  #hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2rem;
    padding: 2rem;
    border-radius: 12px;
    color: white;
  }
  #hero-content p {
    font-size: 1.25rem;
    margin: 0;
    font-weight: 300;
  }
  .pillars {
    display: flex;
    gap: 2rem;
    margin: auto;
    max-width: 90rem;
  }

  .pillars-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }
</style>
