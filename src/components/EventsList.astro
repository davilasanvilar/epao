---
import EventCard from "./EventCard.astro";

export interface Props {
  page: {
    data: any[];
    currentPage: number;
    lastPage: number;
    url: {
      prev: string | undefined;
      next: string | undefined;
    };
  };
  eventType: "future" | "past";
}

const { page, eventType } = Astro.props;
---

<div class="events-grid-wrapper">
  {
    page.data.length === 0 ? (
      <div class="events-empty">No {eventType} events found.</div>
    ) : (
      <div class="events-grid">
        {page.data.map((event) => (
          <EventCard event={event} />
        ))}
      </div>
    )
  }

  <!-- Skeleton loading placeholders -->
  <div class="skeleton-container">
    {
      [1, 2, 3].map(() => (
        <div class="skeleton-card">
          <div class="skeleton-pulse skeleton-image" />
          <div class="skeleton-body">
            <div class="skeleton-meta">
              <div class="skeleton-pulse skeleton-title" />
              <div class="skeleton-pulse skeleton-date" />
            </div>
            <div class="skeleton-pulse skeleton-price" />
            <div class="skeleton-pulse skeleton-line skeleton-line--full" />
            <div class="skeleton-pulse skeleton-line skeleton-line--long" />
            <div class="skeleton-pulse skeleton-line skeleton-line--medium" />
            <div class="skeleton-pulse skeleton-line skeleton-line--short" />
          </div>
        </div>
      ))
    }
  </div>
</div>

{
  page.lastPage > 1 && (
    <div class="events-pagination">
      {page.url.prev ? (
        <a href={page.url.prev} class="pagination-btn">
          Previous
        </a>
      ) : (
        <button disabled class="pagination-btn">
          Previous
        </button>
      )}

      <span class="pagination-info">
        Page {page.currentPage} of {page.lastPage}
      </span>

      {page.url.next ? (
        <a href={page.url.next} class="pagination-btn">
          Next
        </a>
      ) : (
        <button disabled class="pagination-btn">
          Next
        </button>
      )}
    </div>
  )
}

<style>
  .events-grid-wrapper {
    min-height: 400px;
    width: 100%;
    position: relative;
  }

  .events-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Skeleton cards */
  .skeleton-container {
    display: none;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skeleton-container.visible {
    display: flex;
  }

  .skeleton-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: var(--border-radius);
    box-shadow:
      0 1px 3px rgb(0 0 0 / 0.08),
      0 1px 2px rgb(0 0 0 / 0.06);
    width: 100%;
    overflow: hidden;
    height: 15rem;
  }

  @media (min-width: 640px) {
    .skeleton-card {
      flex-direction: row;
    }
  }

  .skeleton-pulse {
    background: linear-gradient(
      90deg,
      hsl(213 22% 92%) 25%,
      hsl(213 22% 96%) 50%,
      hsl(213 22% 92%) 75%
    );
    background-size: 200% 100%;
    animation: skeleton-shimmer 1.5s ease-in-out infinite;
    border-radius: 4px;
  }

  @keyframes skeleton-shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  .skeleton-image {
    flex-shrink: 0;
    height: 15rem;
    border-radius: 0;
  }

  @media (max-width: 639px) {
    .skeleton-image {
      width: 100%;
    }
  }

  @media (min-width: 640px) {
    .skeleton-image {
      width: 280px;
      height: auto;
    }
  }

  @media (min-width: 1024px) {
    .skeleton-image {
      width: 340px;
    }
  }

  .skeleton-body {
    flex: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    gap: 0.75rem;
  }

  .skeleton-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .skeleton-title {
    height: 1.35rem;
    width: 55%;
  }

  .skeleton-date {
    height: 0.85rem;
    width: 6rem;
  }

  .skeleton-price {
    height: 1.1rem;
    width: 4rem;
  }

  .skeleton-line {
    height: 0.95rem;
  }

  .skeleton-line--full {
    width: 100%;
  }
  .skeleton-line--long {
    width: 90%;
  }
  .skeleton-line--medium {
    width: 70%;
  }
  .skeleton-line--short {
    width: 45%;
  }

  .events-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 300px;
    font-size: 1.125rem;
    color: var(--black);
    opacity: 0.7;
  }

  .events-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .pagination-btn {
    padding: 0.5rem 1.25rem;
    background-color: var(--primary-500);
    color: white;
    border: none;
    border-radius: var(--border-radius);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
  }

  .pagination-btn:hover:not(:disabled) {
    background-color: var(--primary-600);
    transform: translateY(-2px);
  }

  .pagination-btn:disabled {
    background-color: var(--gray-300);
    cursor: not-allowed;
    opacity: 0.7;
  }

  .pagination-info {
    font-weight: 500;
    color: var(--black);
  }
</style>

<script>
  // Show skeleton cards during Astro ViewTransitions (only for events pages)
  document.addEventListener("astro:before-preparation", (e) => {
    const destination = e.to?.pathname || "";
    if (!destination.startsWith("/events")) return;

    const grid = document.querySelector(".events-grid") as HTMLElement;
    const skeletons = document.querySelector(
      ".skeleton-container",
    ) as HTMLElement;
    const pagination = document.querySelector(
      ".events-pagination",
    ) as HTMLElement;

    if (grid) grid.style.display = "none";
    if (skeletons) skeletons.classList.add("visible");
    if (pagination) pagination.style.display = "none";
  });

  document.addEventListener("astro:page-load", () => {
    const grid = document.querySelector(".events-grid") as HTMLElement;
    const skeletons = document.querySelector(
      ".skeleton-container",
    ) as HTMLElement;
    const pagination = document.querySelector(
      ".events-pagination",
    ) as HTMLElement;

    if (grid) grid.style.display = "";
    if (skeletons) skeletons.classList.remove("visible");
    if (pagination) pagination.style.display = "";
  });
</script>
