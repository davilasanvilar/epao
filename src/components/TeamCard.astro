---
const { name, role, description, image } = Astro.props;
---

<div class="team-card">
  <div class="team-card-image-container">
    <img src={image.src} alt={name} class="team-card-image" />
    <div class="team-card-image-overlay"></div>
  </div>
  <div class="team-card-body">
    <div class="team-card-info">
      <h3>{name}</h3>
      <span class="team-card-role">{role}</span>
    </div>
    <div class="team-card-quote">
      <p>{description}</p>
    </div>
  </div>
</div>

<style>
  .team-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .team-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 4px 24px hsl(207 30% 30% / 0.08),
      0 1px 3px hsl(207 30% 30% / 0.06);
    transition:
      transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
  }

  /* Card Image */
  .team-card-image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .team-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .team-card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      hsl(207 35% 20% / 0.4) 0%,
      transparent 50%
    );
    pointer-events: none;
  }

  /* Card Body */
  .team-card-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    flex: 1;
  }

  .team-card-info h3 {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--black);
  }

  .team-card-role {
    display: inline-block;
    margin-top: 0.35rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--primary-500);
    background: hsl(207 30% 92%);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
  }

  .team-card-quote {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border-top: 1px solid hsl(0 0% 90%);
    padding-top: 1.25rem;
  }

  .team-card-quote h4 {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 700;
    color: hsl(207 30% 40%);
    font-style: italic;
  }

  .team-card-quote p {
    font-size: 0.9rem !important;
    line-height: 1.65 !important;
    color: hsl(0 0% 35%) !important;
  }
</style>
