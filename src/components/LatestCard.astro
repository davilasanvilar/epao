---
const { title, description, date, img } = Astro.props;
---

<div class="latest-card">
  <img src={img} alt="" />
  <div class="card-content">
    <span class="date">{date}</span>
    <h3>{title}</h3>
    <p class="latest-card__description">{description}</p>
    {
      description && description.length > 0 && (
        <button class="latest-card__toggle" data-expanded="false">
          Show more
          <svg
            class="latest-card__toggle-icon"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </button>
      )
    }
  </div>
</div>

<style>
  .latest-card {
    display: flex;
    flex-direction: column;
  }

  img {
    width: 100%;
    object-fit: cover;
    border-radius: var(--border-radius);
    aspect-ratio: 16 / 9;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
    padding: 1rem;
  }

  .date {
    margin-top: 1rem;
    color: var(--primary-500);
    font-size: 1rem;
    font-weight: 500;
  }

  h3 {
    margin: 0;
    margin-top: 1rem;
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--black);
  }

  .latest-card__description {
    margin: 0;
    margin-top: 1rem;
    color: var(--black);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.5;
    white-space: wrap;
    overflow: hidden;
    -webkit-box-orient: vertical;

    display: -webkit-box;
    -webkit-line-clamp: 2;
  }

  .latest-card__description.expanded {
    -webkit-line-clamp: unset;
    display: block;
  }

  .latest-card__toggle {
    all: unset;
    display: none;
    align-items: center;
    gap: 0.35rem;
    cursor: pointer;
    color: var(--primary-500);
    font-size: 0.875rem;
    font-weight: 600;
    margin-top: 0.25rem;
    transition: color 0.2s ease;
    align-self: flex-start;
  }

  .latest-card__toggle:hover {
    color: var(--primary-600, var(--primary-500));
  }

  .latest-card__toggle-icon {
    transition: transform 0.3s ease;
  }

  .latest-card__toggle[data-expanded="true"] .latest-card__toggle-icon {
    transform: rotate(180deg);
  }

  @media (max-width: 1024px) {
    .card-content {
      padding: 0;
    }
  }
</style>

<script>
  function initializeLatestCards() {
    const toggleButtons = document.querySelectorAll(
      ".latest-card__toggle",
    ) as NodeListOf<HTMLElement>;

    toggleButtons.forEach((btn) => {
      if (btn.hasAttribute("data-initialized")) return;

      const card = btn.closest(".latest-card");
      const description = card?.querySelector(".latest-card__description");

      if (description && description.scrollHeight > description.clientHeight) {
        btn.style.display = "inline-flex";
      }

      btn.addEventListener("click", () => {
        if (!description) return;

        const isExpanded = btn.getAttribute("data-expanded") === "true";

        if (isExpanded) {
          description.classList.remove("expanded");
          btn.setAttribute("data-expanded", "false");
          btn.childNodes[0].textContent = "Show more";
        } else {
          description.classList.add("expanded");
          btn.setAttribute("data-expanded", "true");
          btn.childNodes[0].textContent = "Show less";
        }
      });

      btn.setAttribute("data-initialized", "true");
    });
  }

  initializeLatestCards();
  document.addEventListener("astro:page-load", initializeLatestCards);
</script>
