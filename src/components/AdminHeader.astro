---
import logo from "../assets/logo.svg";
import { useTranslations } from "../i18n";

const currentPath = Astro.url.pathname;
const i18n = useTranslations();
---

<header>
  <div id="logo-container">
    <img src={logo.src} alt="" width="40" height="40" />
    <span class="logo">{i18n.site.adminTitle}</span>
  </div>
  <nav>
    <ul>
      <li class={`nav-item ${currentPath.includes("/admin/requests") ? "active" : ""}`}>
        <a href="/admin/requests">{i18n.admin.header.requests}</a>
      </li>
      <li class={`nav-item ${currentPath.includes("/admin/events") ? "active" : ""}`}>
        <a href="/admin/events">{i18n.admin.header.events}</a>
      </li>
      <li class={`nav-item ${currentPath.includes("/admin/resources") ? "active" : ""}`}>
        <a href="/admin/resources">{i18n.admin.header.resources}</a>
      </li>
    </ul>
  </nav>
  <div class="placeholder-for-alignment"></div>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 5rem;
    padding: 1rem;
    position: fixed;
    top: 0;
    background-color: hsl(240deg 10% 94% / 86%);
    z-index: 1000;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    background-color: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }
  #logo-container {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .logo {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--primary-500);
  }
  nav ul {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .active {
    color: var(--button-primary);
    border-bottom: 2px solid var(--button-primary);
    padding-bottom: 0.25rem;
    font-weight: bold;
  }

  .nav-item {
    margin-right: 1rem;
    list-style: none;
  }
  .nav-item a {
    text-decoration: none;
    color: var(--primary-500);
  }

  .placeholder-for-alignment {
    width: 100px; /* To balance the logo on the left */
  }
</style>