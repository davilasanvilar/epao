---
import LatestCard from "./LatestCard.astro";
import lecture from "../assets/lecture.webp";
import lecture2 from "../assets/lecture2.webp";
import lecture3 from "../assets/lecture3.jfif";
import { env } from "cloudflare:workers";
import { getTursoClient } from "../lib/tursoclient";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";

dayjs.extend(utc);

const PAGE_SIZE = 3;

const url = env.TURSO_CONNECTION_URL || import.meta.env.TURSO_CONNECTION_URL;
const token = env.TURSO_AUTH_TOKEN || import.meta.env.TURSO_AUTH_TOKEN;

if (!url || !token) {
  console.error("Missing Turso configuration.");
}

const turso = url && token ? getTursoClient(url, token) : null;

let events: any[] = [];

if (turso) {
  const dataResult = await turso.execute({
    sql: `SELECT * FROM events WHERE substr(date, 1, 10) < date('now', 'localtime') ORDER BY date DESC LIMIT ? OFFSET ?`,
    args: [PAGE_SIZE, 0],
  });

  events = dataResult.rows.map((row: any) => ({
    id: row.id,
    name: row.name,
    description: row.description,
    price: row.price,
    date: row.date,
    img: row.img,
  }));
}

const formattedEvents = events.map((event) => ({
  name: event.name,
  description: event.description,
  date: dayjs.utc(event.date).local().format("MMMM DD, YYYY"),
  img: event.img
    ? `/api/b2-image?key=${encodeURIComponent(event.img)}`
    : event.imgUrl || "https://placehold.co/400x300?text=No+Image",
}));
---

<section id="latest-activities" class="front-section">
  <div id="latest-activities-content" class="front-section-content">
    <div id="latest-activities-header">
      <div id="latest-activities-title">
        <h2>Latest Events</h2>
      </div>
      <a href="/events" id="view-all-activities">View all events</a>
    </div>
    <div id="latest-activities-list">
      {
        formattedEvents.map((event) => (
          <LatestCard
            title={event.name}
            description={event.description}
            date={event.date}
            img={event.img}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  #latest-activities {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2rem;
    background: linear-gradient(180deg, hsl(213 22% 86% / 1) 10%, transparent 100%);
  }
  #latest-activities-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    width: 100%;
  }

  #latest-activities-header a {
    text-decoration: none;
  }

  #latest-activities-title {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  #latest-activities-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  #view-all-activities {
    color: var(--primary-500);
    font-size: 1rem;
    border-bottom: 2px solid var(--primary-500);
    padding-bottom: 0.25rem;
    cursor: pointer;
    font-weight: bold;
    margin-left: auto;
  }
  #latest-activities-list {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    grid-gap: 2rem;
    justify-content: center;
    gap: 2rem;
  }

  @media (max-width: 1024px) {
    #latest-activities-list :global(.latest-card:nth-child(3)) {
      display: none;
    }
  }
</style>
