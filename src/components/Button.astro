---
const { text } = Astro.props;
---

<button>{text}</button>

<style>
  button {
    background-color: var(--button-primary);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 16px;
    font-weight: bold;
    font-family: var(--font-manrope);
  }
</style>
