---
const { text, variant } = Astro.props;
const bg = variant == "primary" ? "var(--button-primary)" : "transparent";
const col =
  variant == "primary" ? "var(--white)" : "var(--button-primary)";
const brd =
  variant == "primary" ? "none" : "1px solid var(--button-primary)";
---

<button>{text}</button>

<style define:vars={{ bg, col, brd }}>
  button {
    background-color: var(--bg);
    color: var(--col);
    width: fit-content;
    border: var(--brd);
    border-radius: var(--border-radius);
 : "1px solid var(--button-primary)";
    padding: 0.75rem 1.5rem;
    border-radius: var(--border-radius);
    text-decoration: none;
    cursor: pointer;
    font-size: 1rem;
    font-weight: bold;
  }
</style>
