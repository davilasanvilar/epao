---
const { text } = Astro.props;
---

<button>{text}</button>

<style>
  button {
    background-color: var(--button-primary);
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: var(--border-radius);
    cursor: pointer;
    font-size: 1rem;
    font-weight: bold;
    font-family: var(--font-manrope);
  }
</style>
