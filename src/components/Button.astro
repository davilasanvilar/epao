---
const { text, variant, command, commandFor, style } = Astro.props;
const bg = variant == "primary" ? "var(--button-primary)" : "transparent";
const col = variant == "primary" ? "var(--white)" : "var(--button-primary)";
const brd = variant == "primary" ? "none" : "1px solid var(--button-primary)";
---

<button commandfor={commandFor} command={command} style={style}>
  <slot name="icon" />
  {text}
</button>

<style define:vars={{ bg, col, brd }}>
  button {
    background-color: var(--bg);
    color: var(--col);
    width: fit-content;
    border: var(--brd);
    border-radius: var(--border-radius);
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    cursor: pointer;
    font-size: 1rem;
    font-weight: bold;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  button :global(svg) {
    width: 1rem;
    height: 1rem;
  }
</style>
