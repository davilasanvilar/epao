---
import Modal from "./Modal.astro";

export interface Props {
  event: {
    id: number;
    name: string;
    description: string;
    price: number;
    date: string;
    img: string;
    imgUrl?: string; // We'll keep this if passed directly, otherwise build the dynamic endpoint
  };
}

const { event } = Astro.props;

// Use the image key to build the URL to our dynamic endpoint, fallback to placeholder
const imageUrl = event.img
  ? `/api/b2-image?key=${encodeURIComponent(event.img)}`
  : event.imgUrl || "https://placehold.co/400x300?text=No+Image";

const modalId = `event-modal-${event.id}`;
---

<!-- The Card -->
<div class="event-card" role="button" tabindex="0" data-modal-target={modalId}>
  <img src={imageUrl} alt={event.name} class="event-img" loading="lazy" />

  <div class="event-content">
    <span class="event-date">{event.date}</span>
    <h3 class="event-title">{event.name}</h3>
  </div>
</div>

<!-- The Modal -->
<Modal id={modalId} title="">
  <div class="modal-layout">
    <div class="modal-left">
      <img src={imageUrl} alt={event.name} class="modal-img" loading="lazy" />
      <h3 class="modal-title">{event.name}</h3>
    </div>
    <div class="modal-right">
      <span class="modal-date">{event.date}</span>
      <div class="modal-price">
        {event.price === 0 ? "Free" : `${event.price} EUR `}
      </div>
      <p class="modal-description">{event.description}</p>
    </div>
  </div>
</Modal>

<style>
  /* Override default modal width for event modals */
  :global(dialog[id^="event-modal-"]) {
    width: 55rem !important;
    max-width: 95vw !important;
  }

  /* Remove extra margin from empty title in modal header */
  :global(dialog[id^="event-modal-"] .header .title:empty) {
    display: none;
  }

  /* Card Styles */
  .event-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow:
      0 4px 6px -1px rgb(0 0 0 / 0.1),
      0 2px 4px -2px rgb(0 0 0 / 0.1);
    cursor: pointer;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    user-select: none;
  }

  .event-card:focus-visible {
    outline: 2px solid var(--primary-500);
    outline-offset: 2px;
  }

  .event-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .event-card:hover .event-img {
    transform: scale(1.05);
  }

  .event-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    background: white;
    z-index: 1;
  }

  .event-date {
    color: var(--primary-500);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .event-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--black);
    line-height: 1.3;
  }

  /* Modal Layout Styles */
  .modal-layout {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .modal-layout {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .modal-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .modal-img {
    width: 100%;
    border-radius: var(--border-radius);
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }

  .modal-title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--black);
  }

  .modal-right {
    flex: 1.2;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .modal-date {
    color: var(--primary-500);
    font-size: 1.125rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .modal-price {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--black);
  }

  .modal-description {
    margin: 0;
    color: var(--black);
    opacity: 0.9;
    font-size: 1rem;
    line-height: 1.6;
    white-space: pre-line;
  }
</style>

<script>
  function initializeEventCards() {
    const cards = document.querySelectorAll(".event-card");
    cards.forEach((card) => {
      if (card.hasAttribute("data-initialized")) return;

      const targetId = card.getAttribute("data-modal-target");
      if (!targetId) return;

      const modal = document.getElementById(
        targetId,
      ) as HTMLDialogElement | null;

      if (modal) {
        const openModal = () => {
          modal.showModal();
        };

        card.addEventListener("click", openModal);
        card.addEventListener("keydown", (e: Event) => {
          const keyboardEvent = e as KeyboardEvent;
          if (keyboardEvent.key === "Enter" || keyboardEvent.key === " ") {
            e.preventDefault();
            openModal();
          }
        });
      }

      card.setAttribute("data-initialized", "true");
    });
  }

  initializeEventCards();
  document.addEventListener("astro:page-load", initializeEventCards);
</script>
