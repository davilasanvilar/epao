---
export interface Props {
  event: {
    id: number;
    name: string;
    description: string;
    price: number;
    date: string;
    img: string;
    imgUrl?: string;
  };
}

const { event } = Astro.props;

// Use the image key to build the URL to our dynamic endpoint, fallback to placeholder
const imageUrl = event.img
  ? `/api/b2-image?key=${encodeURIComponent(event.img)}`
  : event.imgUrl || "https://placehold.co/400x300?text=No+Image";

// Format date as dd/MM/YY hh:mm
function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  const day = String(d.getDate()).padStart(2, "0");
  const month = String(d.getMonth() + 1).padStart(2, "0");
  const year = String(d.getFullYear()).slice(-2);
  const hours = String(d.getHours()).padStart(2, "0");
  const minutes = String(d.getMinutes()).padStart(2, "0");
  return `${day}/${month}/${year} ${hours}:${minutes}`;
}

const formattedDate = formatDate(event.date);
---

<article class="event-card" data-event-id={event.id}>
  <div class="event-card__image-wrapper">
    <img src={imageUrl} alt={event.name} class="event-card__image" loading="lazy" />
  </div>

  <div class="event-card__body">
    <div class="event-card__meta">
      <h3 class="event-card__title">{event.name}</h3>
      <span class="event-card__date">{formattedDate}</span>
    </div>

    <div class="event-card__price">
      {event.price === 0 ? "Free" : `${event.price} €`}
    </div>

    <div class="event-card__description-wrapper">
      <p class="event-card__description">{event.description}</p>
    </div>

    {
      event.description && event.description.length > 0 && (
        <button class="event-card__toggle" data-expanded="false">
          Show more
          <svg
            class="event-card__toggle-icon"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </button>
      )
    }
  </div>
</article>

<style>
  .event-card {
    display: flex;
    min-height: 15rem;
    flex-direction: column;
    background: white;
    border-radius: var(--border-radius);
    box-shadow:
      0 1px 3px rgb(0 0 0 / 0.08),
      0 1px 2px rgb(0 0 0 / 0.06);
    width: 100%;
  }

  @media (min-width: 640px) {
    .event-card {
      flex-direction: row;
    }
  }

  /* Image */
  .event-card__image-wrapper {
    flex-shrink: 0;
    overflow: hidden;
    border-top-left-radius: var(--border-radius);
    border-bottom-left-radius: var(--border-radius);
  }

  @media (max-width: 639px) {
    .event-card__image-wrapper {
      width: 100%;
      max-height: 220px;
    }
  }

  @media (min-width: 640px) {
    .event-card__image-wrapper {
      width: 280px;
    }
  }

  @media (min-width: 1024px) {
    .event-card__image-wrapper {
      width: 340px;
    }
  }

  .event-card__image {
    width: 100%;
    max-height: 15rem;
    object-fit: cover;
    display: block;
  }

  /* Body */
  .event-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    gap: 0.5rem;
    min-width: 0;
  }

  /* Meta: date + title */
  .event-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .event-card__date {
    color: var(--primary-500);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .event-card__title {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--black);
    line-height: 1.3;
  }

  /* Price */
  .event-card__price {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--primary-600, var(--primary-500));
  }

  /* Description */
  .event-card__description-wrapper {
    overflow: hidden;
  }

  .event-card__description {
    margin: 0;
    color: var(--black);
    opacity: 0.75;
    font-size: 0.95rem;
    line-height: 1.6;
    white-space: pre-line;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .event-card__description.expanded {
    -webkit-line-clamp: unset;
    display: block;
  }

  /* Toggle button */
  .event-card__toggle {
    all: unset;
    display: none;
    align-items: center;
    gap: 0.35rem;
    cursor: pointer;
    color: var(--primary-500);
    font-size: 0.875rem;
    font-weight: 600;
    margin-top: 0.25rem;
    transition: color 0.2s ease;
    align-self: flex-start;
  }

  .event-card__toggle:hover {
    color: var(--primary-600, var(--primary-500));
  }

  .event-card__toggle-icon {
    transition: transform 0.3s ease;
  }

  .event-card__toggle[data-expanded="true"] .event-card__toggle-icon {
    transform: rotate(180deg);
  }
</style>

<script>
  function initializeEventCards() {
    const toggleButtons = document.querySelectorAll(
      ".event-card__toggle",
    ) as NodeListOf<HTMLElement>;

    toggleButtons.forEach((btn) => {
      if (btn.hasAttribute("data-initialized")) return;

      const card = btn.closest(".event-card");
      const description = card?.querySelector(".event-card__description");

      // Check if text is overflowing the 2-line clamp
      if (description && description.scrollHeight > description.clientHeight) {
        btn.style.display = "inline-flex";
      }

      btn.addEventListener("click", () => {
        if (!description) return;

        const isExpanded = btn.getAttribute("data-expanded") === "true";

        if (isExpanded) {
          description.classList.remove("expanded");
          btn.setAttribute("data-expanded", "false");
          btn.childNodes[0].textContent = "Show more";
        } else {
          description.classList.add("expanded");
          btn.setAttribute("data-expanded", "true");
          btn.childNodes[0].textContent = "Show less";
        }
      });

      btn.setAttribute("data-initialized", "true");
    });
  }

  initializeEventCards();
  document.addEventListener("astro:page-load", initializeEventCards);
</script>
