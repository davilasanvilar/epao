---
export interface Props {
  event: {
    id: number;
    name: string;
    description: string;
    price: number;
    date: string;
    img: string;
    imgUrl?: string; // We'll keep this if passed directly, otherwise build the dynamic endpoint
  };
}

const { event } = Astro.props;

// Use the image key to build the URL to our dynamic endpoint, fallback to placeholder
const imageUrl = event.img
  ? `/api/b2-image?key=${encodeURIComponent(event.img)}`
  : event.imgUrl || "https://placehold.co/400x300?text=No+Image";
---

<div class="event-card" role="button" tabindex="0">
  <img src={imageUrl} alt={event.name} class="event-img" loading="lazy" />

  <div class="event-content">
    <span class="event-date">{event.date}</span>
    <h3 class="event-title">{event.name}</h3>

    <div class="event-details-wrapper">
      <div class="event-details-inner">
        <p class="event-description">{event.description}</p>
        <div class="event-price">
          {event.price === 0 ? "Free" : `${event.price} EUR `}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow:
      0 4px 6px -1px rgb(0 0 0 / 0.1),
      0 2px 4px -2px rgb(0 0 0 / 0.1);
    cursor: pointer;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    user-select: none;
  }

  .event-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 10px 15px -3px rgb(0 0 0 / 0.1),
      0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  .event-card:focus-visible {
    outline: 2px solid var(--primary-500);
    outline-offset: 2px;
  }

  .event-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .event-card:hover .event-img {
    transform: scale(1.05);
  }

  .event-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    background: white;
    z-index: 1;
  }

  .event-date {
    color: var(--primary-500);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .event-title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--black);
    line-height: 1.3;
  }

  .event-details-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .event-card.open .event-details-wrapper {
    grid-template-rows: 1fr;
  }

  .event-details-inner {
    overflow: hidden;
  }

  .event-description {
    margin: 1rem 0 0 0;
    color: var(--black);
    opacity: 0.8;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .event-price {
    margin-top: 1rem;
    font-weight: 600;
    color: var(--primary-500);
    font-size: 1.125rem;
  }
</style>

<script>
  // Add interactive click behavior to event cards
  function initializeEventCards() {
    const cards = document.querySelectorAll(".event-card");
    cards.forEach((card) => {
      // Avoid adding multiple listeners if re-initialized
      if (card.hasAttribute("data-initialized")) return;

      card.addEventListener("click", () => {
        card.classList.toggle("open");
      });

      card.addEventListener("keydown", (e: Event) => {
        const keyboardEvent = e as KeyboardEvent;
        if (keyboardEvent.key === "Enter" || keyboardEvent.key === " ") {
          e.preventDefault();
          card.classList.toggle("open");
        }
      });

      card.setAttribute("data-initialized", "true");
    });
  }

  // Run on initial load and after view transitions (if enabled in the future)
  initializeEventCards();
  document.addEventListener("astro:page-load", initializeEventCards);
</script>
